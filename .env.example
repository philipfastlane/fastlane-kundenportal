# SMTP-Konfiguration für E-Mail-Versand
# Kopieren Sie diese Datei zu .env und tragen Sie Ihre Zugangsdaten ein

SMTP_HOST=mail.fastlanesolutions.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=philip@fastlanesolutions.de
SMTP_PASS=IhrPasswortHier

# Portal-URL (für Links in E-Mails)
PORTAL_URL=http://localhost:5173

# JWT Secret (in Produktion ändern!)
JWT_SECRET=kundenportal-geheimschluessel-2024
